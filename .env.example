# URL of the realtime Socket.IO server (the server/ package).
# Local dev: http://localhost:4000
# Production: your Render/Railway URL, e.g. https://truth-n-dare-server.onrender.com
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# Optional: enables live AI-generated prompts via the /api/prompt route.
# Without it, the curated prompt pool is used as the fallback.
OPENAI_API_KEY=

# Reserved for future Supabase-backed persistence (not yet wired).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
